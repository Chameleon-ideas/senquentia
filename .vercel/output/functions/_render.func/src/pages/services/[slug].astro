---
import Layout from '../../layouts/Layout.astro';
import { getServiceBySlug, getServiceSlugs } from '../../sanity/queries';
import { urlFor } from '../../sanity/image';
import { PortableText } from 'astro-portabletext';

export async function getStaticPaths() {
  const slugs = await getServiceSlugs();
  return slugs.map((s: { slug: string }) => ({ params: { slug: s.slug } }));
}

const { slug } = Astro.params;
const service = await getServiceBySlug(slug!);

if (!service) return Astro.redirect('/services');

const title = typeof service.title === 'object' ? service.title.en : service.title;

const heroBgStyle = service.heroBgImage
  ? `background-image:url('${urlFor(service.heroBgImage).width(1920).url()}')`
  : service.image
    ? `background-image:url('${urlFor(service.image).width(1920).url()}')`
    : '';

const perspectiveCol1 = service.perspectiveCol1 ?? [];
const perspectiveCol2 = service.perspectiveCol2 ?? [];
const approachSections = service.approachSections ?? [];
const industries = service.industriesEngaged ?? [];
---

<Layout title={service.seoTitle ?? title} description={service.seoDescription}>
  <!-- ═══ HERO ══════════════════════════════════════════════ -->
  <section class="page-hero">
    <div class="page-hero-bg" style={heroBgStyle}></div>
    <div class="page-hero-label">
      <h1>{title}</h1>
      <div class="page-hero-bar"></div>
    </div>
  </section>

  <!-- ═══ PERSPECTIVE ═══════════════════════════════════════ -->
  <section class="perspective-section">
    <div class="container">
      <h2 class="perspective-label reveal-up">Perspective</h2>
      <div class="perspective-grid">
        <div class="perspective-col reveal-left">
          {perspectiveCol1.length > 0
            ? <PortableText value={perspectiveCol1} />
            : service.perspectiveText && <p>{service.perspectiveText}</p>
          }
        </div>
        <div class="perspective-col reveal-right">
          {perspectiveCol2.length > 0
            ? <PortableText value={perspectiveCol2} />
            : service.perspectiveText2 && <p>{service.perspectiveText2}</p>
          }
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ QUOTE ════════════════════════════════════════════ -->
  {service.quoteText && (
    <section class="service-quote-section">
      <div class="container">
        <p class="service-quote-text reveal-up">{service.quoteText}</p>
      </div>
    </section>
  )}

  <!-- ═══ APPROACH ═════════════════════════════════════════ -->
  <section class="approach-section">
    <div class="container">
      <h2 class="approach-label reveal-up">Approach</h2>
      {service.approachLead && (
        <p class="approach-lead">{service.approachLead}</p>
      )}
      {approachSections.length > 0 && (
        <div class="approach-blocks">
          {approachSections.map((s: any) => (
            <div class="approach-block reveal-up">
              <h3 class="approach-block-title">{s.title}</h3>
              <p class="approach-block-body">{s.body}</p>
            </div>
          ))}
        </div>
      )}

      {industries.length > 0 && (
        <div class="industries-table">
          <p class="industries-label">Organizations engage us in moments such as these</p>
          {industries.map((row: any) => (
            <div class="industries-row">
              <span class="industry-name">{row.label}</span>
              <span class="industry-desc">{row.description}</span>
            </div>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- ═══ CLOSING ═══════════════════════════════════════════ -->
  {service.closingText && (
    <section class="service-closing">
      <div class="container">
        <p class="service-closing-text reveal-up">{service.closingText}</p>
      </div>
    </section>
  )}
</Layout>
