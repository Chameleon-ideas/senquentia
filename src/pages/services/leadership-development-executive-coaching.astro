---
import Layout from "../../layouts/Layout.astro";
---

<Layout
  title="Leadership Development & Executive Coaching"
  description="Strengthening leadership capability and providing confidential advisory support."
>
  <div class="services-page-wrap">
    <!-- Section 1: Hero -->
    <section class="svc-hero">
      <div class="svc-hero-bg">
        <img src="/images/servicesherobg3.png" alt="" />
      </div>
      <div class="svc-hero-container">
        <div class="svc-hero-box">
          <div class="svc-hero-text-row">
            <h1 class="svc-hero-title" style="font-weight: 400;">
              LEADERSHIP DEVELOPMENT <br />& EXECUTIVE COACHING.
            </h1>
            <div class="svc-hero-bar"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Section 2: Leadership Development & Executive Coaching -->
    <section class="svc-perspective">
      <div class="container">
        <div class="svc-dual-grid">
          <div class="svc-dual-left">
            <h2 class="svc-dual-title">LEADERSHIP <br /> DEVELOPMENT</h2>
            <p class="svc-dual-body-left">
              Leaders engage us when they are navigating moments such as
              stepping into new executive roles, leading organizations through
              transformation, preparing leadership teams for growth or change,
              strengthening leadership alignment, or managing complex
              organizational and cultural dynamics.
            </p>
          </div>
          <div class="svc-perspective-divider"></div>
          <div class="svc-dual-right">
            <h2 class="svc-dual-title">EXECUTIVE <br /> COACHING</h2>
            <p class="svc-dual-body-right">
              In addition to our work with organizations, we support individual
              leaders seeking a confidential space to reflect, navigate
              complexity, and strengthen their leadership approach.
            </p>
            <p class="svc-dual-body-right">
              These engagements are tailored to the unique context of each
              leader and often focus on periods of transition, increased
              responsibility, or complex organizational dynamics.
            </p>
            <p class="svc-dual-body-right">
              Our work is grounded in discretion, trust, and thoughtful
              dialogue, providing leaders with the space and perspective to
              navigate their responsibilities with clarity and confidence.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Section 3 & 4: Alignment & Impact -->
    <section class="svc-alignment">
      <div class="svc-alignment-bg">
        <img src="/images/servicesherobg3.png" alt="" />
      </div>

      <!-- Alignment Box -->
      <div class="container svc-alignment-container">
        <div class="svc-alignment-box2">
          <div class="svc-alignment-top2">
            <h3 class="svc-alignment-title" style="font-weight: 500;">
              Leadership effectiveness shapes an organization’s ability to
              navigate change and sustain performance.
            </h3>
          </div>
          <div class="svc-alignment-bottom">
            <p class="svc-alignment-desc">
              We work with senior leaders to strengthen leadership capability
              and provide confidential advisory support as they guide
              organizations through complex environments.
              <br />
              <br />
              Our approach is thoughtful, discreet, and tailored to the needs of each
              leader and organization.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Section 4: Approach -->
    <section class="svc-asym-section">
      <div class="container">
        <div class="svc-asym-header-row">
          <h2 class="svc-asym-title">APPROACH</h2>
        </div>
        <div class="svc-asym-lead-row">
          <p class="svc-asym-lead-text">
            Our work focuses on helping leaders strengthen their capacity <br />
            to lead with clarity, perspective, and confidence.
          </p>
        </div>
        <div class="svc-asym-line-row">
          <div class="svc-asym-line"></div>
        </div>
        <div class="svc-asym-body-row">
          <p class="svc-asym-body-text">
            Through structured dialogue and practical insight, we support
            leaders in developing the judgment, self-awareness, and leadership
            presence required to guide organizations through complex
            environments.
          </p>
        </div>
      </div>
    </section>

    <!-- Section 6: Impact -->
    <section class="svc-alignment">
      <div class="svc-alignment-bg">
        <img src="/images/servicesherobg3.png" alt="" />
      </div>

      <!-- Impact Box -->
      <div class="container svc-alignment-container">
        <div class="svc-alignment-box">
          <div class="svc-impact-top">
            <h3 class="svc-impact-title">LEADERSHIP</h3>
            <div class="svc-impact-text">
              <p>
                Leadership development is ultimately about helping leaders
                navigate complexity with confidence while strengthening the
                organizations they lead.
              </p>
            </div>
          </div>
          <div class="svc-impact-bottom">
            <h4 class="svc-impact-footer">
              We welcome conversations with leadership teams leading through
              complexity and transition. Connect.
            </h4>
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>
