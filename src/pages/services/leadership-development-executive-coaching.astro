---
import Layout from "../../layouts/Layout.astro";
import { getServiceBySlug, urlFor } from "@/utils/sanity";
import { t } from "@/utils/i18n";

const lang = "en";
const service = await getServiceBySlug("leadership-development-executive-coaching");

if (!service) {
  return Astro.redirect("/404");
}

const heroBgUrl = service?.heroBgImage
  ? urlFor(service.heroBgImage).width(1920).url()
  : "/images/servicesherobg3.png";

const alignmentBgUrl = service?.alignmentImage
  ? urlFor(service.alignmentImage).width(1920).url()
  : "/images/servicesherobg3.png";

const closingBgUrl = service?.closingImage
  ? urlFor(service.closingImage).width(1920).url()
  : "/images/servicesherobg3.png";
---

<Layout
  title={t(service?.seoTitle, lang) || "Leadership Development & Executive Coaching | Senquentia"}
  description={t(service?.seoDescription, lang) || t(service?.shortDescription, lang)}
  lang={lang}
>
  <div class="services-page-wrap">
    <!-- Section 1: Hero -->
    <section class="svc-hero">
      <div class="svc-hero-bg">
        <img src={heroBgUrl} alt="" />
      </div>
      <div class="svc-hero-container">
        <div class="svc-hero-box">
          <div class="svc-hero-text-row">
            <h1 class="svc-hero-title" style="font-weight: 400;">
              {t(service?.title, lang).toUpperCase()}.
            </h1>
            <div class="svc-hero-bar"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Section 2: Leadership Development & Executive Coaching -->
    <section class="svc-perspective">
      <div class="container">
        <div class="svc-dual-grid">
          <div class="svc-dual-left">
            <h2 class="svc-dual-title">
              {t(service?.perspectiveTitle1, lang) || "LEADERSHIP DEVELOPMENT"}
            </h2>
            <p class="svc-dual-body-left">
              {t(service?.perspectiveLead1, lang) || "Leaders engage us when they are navigating moments such as stepping into new executive roles, leading organizations through transformation, preparing leadership teams for growth or change, strengthening leadership alignment, or managing complex organizational and cultural dynamics."}
            </p>
          </div>
          <div class="svc-perspective-divider"></div>
          <div class="svc-dual-right">
            <h2 class="svc-dual-title">
              {t(service?.perspectiveTitle2, lang) || "EXECUTIVE COACHING"}
            </h2>
            <div class="svc-dual-body-right">
              {
                service?.perspectiveBody ? (
                   <div class="rich-content">
                     {/* Render perspectiveBody rich text */}
                   </div>
                ) : (
                  <>
                    <p>
                      In addition to our work with organizations, we support individual
                      leaders seeking a confidential space to reflect, navigate
                      complexity, and strengthen their leadership approach.
                    </p>
                    <p>
                      These engagements are tailored to the unique context of each
                      leader and often focus on periods of transition, increased
                      responsibility, or complex organizational dynamics.
                    </p>
                    <p>
                      Our work is grounded in discretion, trust, and thoughtful
                      dialogue, providing leaders with the space and perspective to
                      navigate their responsibilities with clarity and confidence.
                    </p>
                  </>
                )
              }
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Section 3 & 4: Alignment & Impact -->
    <section class="svc-alignment">
      <div class="svc-alignment-bg">
        <img src={alignmentBgUrl} alt="" />
      </div>

      <!-- Alignment Box -->
      <div class="container svc-alignment-container">
        <div class="svc-alignment-box2">
          <div class="svc-alignment-top2">
            <h3 class="svc-alignment-title" style="font-weight: 500;">
              {t(service?.quoteText, lang) || "Leadership effectiveness shapes an organization’s ability to navigate change and sustain performance."}
            </h3>
          </div>
          <div class="svc-alignment-bottom">
            <p class="svc-alignment-desc">
              {t(service?.alignmentBody, lang) || "We work with senior leaders to strengthen leadership capability and provide confidential advisory support as they guide organizations through complex environments."}
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Section 4: Approach -->
    <section class="svc-asym-section">
      <div class="container">
        <div class="svc-asym-header-row">
          <h2 class="svc-asym-title">{lang === 'fr' ? "APPROCHE" : "APPROACH"}</h2>
        </div>
        <div class="svc-asym-lead-row">
          <p class="svc-asym-lead-text">
            {t(service?.approachLead, lang) || "Our work focuses on helping leaders strengthen their capacity to lead with clarity, perspective, and confidence."}
          </p>
        </div>
        <div class="svc-asym-line-row">
          <div class="svc-asym-line"></div>
        </div>
        <div class="svc-asym-body-row">
          <p class="svc-asym-body-text">
            {t(service?.approachBody, lang) || "Through structured dialogue and practical insight, we support leaders in developing the judgment, self-awareness, and leadership presence required to guide organizations through complex environments."}
          </p>
        </div>
      </div>
    </section>

    <!-- Section 6: Impact -->
    <section class="svc-alignment">
      <div class="svc-alignment-bg">
        <img src={closingBgUrl} alt="" />
      </div>

      <!-- Impact Box -->
      <div class="container svc-alignment-container">
        <div class="svc-alignment-box">
          <div class="svc-impact-top">
            <h3 class="svc-impact-title">{t(service?.closingTitle, lang) || "LEADERSHIP"}</h3>
            <div class="svc-impact-text">
               {
                 service?.closingBody ? (
                    <div class="rich-content">
                      {/* Render closingBody */}
                    </div>
                 ) : (
                   <p>
                     Leadership development is ultimately about helping leaders
                     navigate complexity with confidence while strengthening the
                     organizations they lead.
                   </p>
                 )
               }
            </div>
          </div>
          <div class="svc-impact-bottom">
            <h4 class="svc-impact-footer">
              {t(service?.closingFooter, lang) || "We welcome conversations with leadership teams leading through complexity and transition. Connect."}
            </h4>
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>
