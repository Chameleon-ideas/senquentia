---
import Layout from "../layouts/Layout.astro";
import { getHomePage, getServices } from "../sanity/queries";
import { urlFor } from "../sanity/image";

const [page, services] = await Promise.all([getHomePage(), getServices()]);

const heroImageSrc = page?.heroBgImage
  ? urlFor(page.heroBgImage).width(1920).url()
  : "/images/hero.png";

const servicesBgStyle = page?.servicesBgImage
  ? `background-image:url('${urlFor(page.servicesBgImage).width(1920).url()}')`
  : "";

const ctaBgStyle = page?.ctaBgImage
  ? `background-image:url('${urlFor(page.ctaBgImage).width(1920).url()}')`
  : `background-image:url('/images/contactbg.png')`;

const stats = page?.stats ?? [
  { number: "500M+", label: "Program budget oversight" },
  { number: "25+", label: "ERP Transformation Programs" },
  { number: "30+", label: "HCM Transformation Programs" },
  { number: "10+", label: "Mergers & Acquisitions" },
];

const industries = [
  "Crown Corporations & Public Sector Entities",
  "Banking & Financial Services",
  "Energy & Utilities",
  "Insurance",
  "Aviation & Aerospace",
  "Transportation & Logistics",
  "Construction & Engineering Services",
  "Pulp, Paper, & Forestry",
  "Mining & Natural Resources",
  "Retail & Consumer Goods",
  "Food & Beverage Manufacturing",
  "Higher Education & Academic Institutions",
];

const displayServices = services?.length
  ? services
  : [
      {
        title: "Digital & Organizational Transformation",
        slug: { current: "digital-organizational-transformation" },
      },
      { title: "Strategic Advisory", slug: { current: "strategic-advisory" } },
      {
        title: "Leadership Development & Executive Coaching",
        slug: { current: "leadership-development-executive-coaching" },
      },
    ];
---

<Layout title={page?.seoTitle} description={page?.seoDescription}>
  <!-- ═══ HERO ══════════════════════════════════════════════ -->
  <section class="home-hero">
    <img src={heroImageSrc} alt="Senquentia" class="home-hero-img" />
  </section>

  <!-- ═══ INTRO ════════════════════════════════════════════ -->
  <section class="intro-section">
    <div class="container2">
      <div class="intro-eyebrow-row">
        <div class="intro-eyebrow-left">
          <div class="intro-eyebrow-line"></div>
          <p class="intro-eyebrow">
            {page?.introEyebrow ?? "Welcome to Senquentia"}
          </p>
        </div>
        <div class="intro-eyebrow-divider"></div>
        <div class="intro-eyebrow-right"></div>
      </div>
      <div class="intro-grid">
        <div class="intro-left">
          <h2
            class="intro-heading reveal-left"
            set:html={page?.introHeadline
              ? page.introHeadline.replace(/\n/g, "<br/>")
              : "WHERE LEADERSHIP<br/>MEETS<br/>TRANSFORMATION"}
          />
        </div>
        <div class="intro-v-divider"></div>
        <div class="intro-right reveal-right">
          <p class="intro-lead">
            {
              page?.introLead ??
                "Since 2010, we have partnered with executive teams to lead complex digital and organizational transformation."
            }
          </p>
          <div class="intro-body">
            {
              page?.introBody ? (
                <p>{page.introBody}</p>
              ) : (
                <>
                  <p>
                    Through our strategy and management consulting services,
                    organizations navigate complexity and drive meaningful
                    change — supported by strategic perspective and a pragmatic,
                    hands-on approach.
                  </p>
                  <p>
                    Our work is grounded in trust and shaped by the unique
                    context of each organization.
                  </p>
                  <p>We focus on delivering lasting impact.</p>
                </>
              )
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ SERVICES ══════════════════════════════════════════ -->
  <section class="services-wrap">
    {
      page?.servicesBgImage ? (
        <img
          class="services-bg-img"
          src={urlFor(page.servicesBgImage).width(1920).url()}
          alt=""
        />
      ) : (
        <img class="services-bg-img" src="/images/services.png" alt="" />
      )
    }
    <div class="services-overlay" id="services-section">
      <div class="container2">
        <div class="services-overlay-inner">
          {
            displayServices.slice(0, 3).map((s: any, i: number) => {
              const fallbackImages = [
                "/images/servicesbox1.png",
                "/images/servicesbox2.png",
                "/images/servicebox3.png",
              ];
              const fallbackUrl = fallbackImages[i] || "/images/services.png";
              const imgUrl =
                s.mainImage || s.image
                  ? `url('${urlFor(s.mainImage || s.image)
                      .width(600)
                      .url()}')`
                  : `url('${fallbackUrl}')`;
              const bgImg = `linear-gradient(rgba(248, 246, 242, 0.7), rgba(248, 246, 242, 0.7)), ${imgUrl}`;
              return (
                <a
                  href={`/services/${s.slug?.current ?? s.slug}`}
                  class="service-overlay-item reveal-up"
                  style={`background-image: ${bgImg}`}
                >
                  <div class="service-overlay-inner-box">
                    <div class="service-overlay-title">
                      {typeof s.title === "object" ? s.title.en : s.title}
                    </div>
                  </div>
                </a>
              );
            })
          }
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ STATS ════════════════════════════════════════════ -->
  <section class="stats-bar">
    <div class="container2">
      <div class="stats-grid">
        {
          stats.map((stat: any) => (
            <div class="reveal-up">
              <div class="stat-number">{stat.number ?? stat.value}</div>
              <div class="stat-label">{stat.label}</div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ═══ TICKER ════════════════════════════════════════════ -->
  <div class="container2 spacing">
    <div class="ticker-wrap" aria-hidden="true">
      <div class="ticker-track">
        {
          [...industries, ...industries].map((item) => (
            <span class="ticker-item">{item}</span>
          ))
        }
      </div>
    </div>
  </div>

  <!-- ═══ CTA ══════════════════════════════════════════════ -->
  <section class="home-cta">
    <div class="home-cta-bg" style={ctaBgStyle}></div>
    <div class="container2">
      <div class="home-cta-content">
        <div class="home-cta-text-wrapper reveal-right">
          <p class="home-cta-text">
            {page?.ctaText ?? "Our work begins in conversation."}
          </p>
          <a href="/contact" class="home-cta-link">
            {page?.ctaLinkLabel ?? "Connect."}
          </a>
        </div>
        <div class="home-cta-bar"></div>
      </div>
    </div>
  </section>
</Layout>
