import Layout from "../layouts/Layout.astro";
import { getConnectPage, urlFor } from "@/utils/sanity";
import { t, getLang } from "@/utils/i18n";
import "../styles/contact.css";

const lang = getLang(Astro.url);
const page = await getConnectPage();

const heroBgUrl = page?.heroBgImage
  ? urlFor(page.heroBgImage).width(1920).url()
  : "/images/contactbg.png";

const email = page?.email ?? "info@senquentia.com";
---

<Layout
  title={t(page?.seoTitle, lang) || (lang === 'fr' ? "Contact | Senquentia" : "Contact | Senquentia")}
  description={t(page?.seoDescription, lang)}
>
  <div
    class="contact-page-outer"
    style={`background-image: url(${heroBgUrl});`}
  >
    <div class="contact-page-inner">
      <!-- Top Right Label -->
      <div class="contact-top-label">
        <h2>{lang === 'fr' ? "CONTACT" : "CONTACT"}</h2>
        <div class="contact-top-bar"></div>
      </div>

      <div class="container">
        <main class="contact-content-main">
          <!-- Intro Text -->
          <div class="contact-intro-text">
            <p>{t(page?.leadText, lang) || (lang === 'fr' ? "Notre travail commence par une conversation." : "Our work begins in conversation.")}</p>
            <p>{lang === 'fr' ? "Connecter." : "Connect."}</p>
          </div>

          <!-- Red Line -->
          <div class="contact-red-line"></div>

          <!-- Form Grid -->
          <form
            id="connect-form"
            class="contact-form-grid"
            method="POST"
            action="/api/contact"
          >
            <!-- Left Col -->
            <div class="contact-form-col">
              <input
                type="text"
                name="name"
                placeholder={lang === 'fr' ? "Nom" : "Name"}
                class="contact-field"
                required
              />
              <input
                type="text"
                name="organization"
                placeholder={lang === 'fr' ? "Organisation" : "Organization"}
                class="contact-field"
              />
              <input
                type="email"
                name="email"
                placeholder="Email"
                class="contact-field"
                required
              />
              <input
                type="tel"
                name="phone"
                placeholder={lang === 'fr' ? "Téléphone" : "Phone"}
                class="contact-field"
              />
            </div>

            <!-- Right Col -->
            <div class="contact-form-col">
              <input
                type="text"
                name="area"
                placeholder={lang === 'fr' ? "Domaine d'intérêt" : "Area of interest"}
                class="contact-field"
              />
              <textarea
                name="message"
                placeholder="Message"
                class="contact-field contact-textarea"
                required></textarea>
            </div>

          </form>

          <!-- Footer row moved outside the grid to allow more width -->
          <div class="contact-footer-right">
            <button
              type="submit"
              id="send-btn"
              form="connect-form"
              class="contact-submit-btn"
              data-sending={lang === 'fr' ? "Envoi en cours…" : "Sending…"}
              data-sent={lang === 'fr' ? "Envoyé ✓" : "Sent ✓"}
              data-error={lang === 'fr' ? "Une erreur est survenue." : "Something went wrong."}
              >{lang === 'fr' ? "ENVOYER" : "SEND"}</button
            >

            <div class="contact-footer-text">
              <p class="contact-disclaimer">
                {
                  t(page?.disclaimer, lang) ||
                    (lang === 'fr' 
                      ? "Nous traitons toutes les demandes avec discrétion et confidentialité."
                      : "We treat all inquiries with discretion and confidentiality.")
                }
              </p>
              <a href={`mailto:${email}`} class="contact-email-link-footer"
                >{email}</a
              >
            </div>
          </div>
        </main>
      </div>
    </div>
  </div>
</Layout>

<script>
  const form = document.getElementById(
    "connect-form",
  ) as HTMLFormElement | null;
  const btn = document.getElementById("send-btn") as HTMLButtonElement | null;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!btn) return;
    btn.disabled = true;
    const originalText = btn.textContent;
    const sendingText = btn.dataset.sending || "Sending…";
    const sentText = btn.dataset.sent || "Sent ✓";
    const errorText = btn.dataset.error || "Something went wrong.";

    btn.textContent = sendingText;

    const data = Object.fromEntries(new FormData(form));
    try {
      const res = await fetch("/api/contact", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
      });
      if (!res.ok) throw new Error();
      btn.textContent = sentText;
      form.reset();
      setTimeout(() => {
        btn.disabled = false;
        btn.textContent = originalText;
      }, 3000);
    } catch {
      btn.disabled = false;
      btn.textContent = originalText;
      alert(errorText);
    }
  });
</script>
