---
import Layout from "../layouts/Layout.astro";
import { getConnectPage } from "../sanity/queries";
import { urlFor } from "../sanity/image";
import "../styles/contact.css";

const page = await getConnectPage();

const heroBgUrl = page?.heroBgImage
  ? urlFor(page.heroBgImage).width(1920).url()
  : "/images/contactbg.png";

const email = page?.email ?? "info@senquentia.com";
---

<Layout
  title={page?.seoTitle ?? "Contact | Senquentia"}
  description={page?.seoDescription}
>
  <div
    class="contact-page-outer"
    style={`background-image: url(${heroBgUrl});`}
  >
    <div class="contact-page-inner">
      <!-- Top Right Label -->
      <div class="contact-top-label">
        <h2>CONTACT</h2>
        <div class="contact-top-bar"></div>
      </div>

      <div class="container">
        <main class="contact-content-main">
          <!-- Intro Text -->
          <div class="contact-intro-text">
            <p>{page?.leadText ?? "Our work begins in conversation."}</p>
            <p>Connect.</p>
          </div>

          <!-- Red Line -->
          <div class="contact-red-line"></div>

          <!-- Form Grid -->
          <form
            id="connect-form"
            class="contact-form-grid"
            method="POST"
            action="/api/contact"
          >
            <!-- Left Col -->
            <div class="contact-form-col">
              <input
                type="text"
                name="name"
                placeholder="Name"
                class="contact-field"
                required
              />
              <input
                type="text"
                name="organization"
                placeholder="Organization"
                class="contact-field"
              />
              <input
                type="email"
                name="email"
                placeholder="Email"
                class="contact-field"
                required
              />
              <input
                type="tel"
                name="phone"
                placeholder="Phone"
                class="contact-field"
              />
            </div>

            <!-- Right Col -->
            <div class="contact-form-col">
              <input
                type="text"
                name="area"
                placeholder="Area of interest"
                class="contact-field"
              />
              <textarea
                name="message"
                placeholder="Message"
                class="contact-field contact-textarea"
                required></textarea>
            </div>

            <!-- Footer row spanning the second column for alignment -->
            <div class="contact-footer-right">
              <button type="submit" id="send-btn" class="contact-submit-btn"
                >SEND</button
              >

              <div class="contact-footer-text">
                <p class="contact-disclaimer">
                  {
                    page?.disclaimer ??
                      "We treat all inquiries with discretion and confidentiality."
                  }
                </p>
                <a href={`mailto:${email}`} class="contact-email-link-footer"
                  >{email}</a
                >
              </div>
            </div>
          </form>
        </main>
      </div>
    </div>
  </div>
</Layout>

<script>
  const form = document.getElementById(
    "connect-form",
  ) as HTMLFormElement | null;
  const btn = document.getElementById("send-btn") as HTMLButtonElement | null;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!btn) return;
    btn.disabled = true;
    const originalText = btn.textContent;
    btn.textContent = "Sending…";

    const data = Object.fromEntries(new FormData(form));
    try {
      const res = await fetch("/api/contact", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
      });
      if (!res.ok) throw new Error();
      btn.textContent = "Sent ✓";
      form.reset();
      setTimeout(() => {
        btn.disabled = false;
        btn.textContent = originalText;
      }, 3000);
    } catch {
      btn.disabled = false;
      btn.textContent = "Send";
      alert("Something went wrong. Please try again or email us directly.");
    }
  });
</script>
