import Layout from "../layouts/Layout.astro";
import "../styles/journal.css";
import { getJournalPage, getBlogPosts, urlFor } from "@/utils/sanity";

const [page, posts] = await Promise.all([getJournalPage(), getBlogPosts()]);

const heroBgUrl = page?.heroBgImage 
  ? urlFor(page.heroBgImage).width(1920).url() 
  : "/images/jouhero.png";

const articles = posts?.length ? posts.map(p => ({
  title: p.title,
  desc: p.excerpt,
  img: p.featuredImage ? urlFor(p.featuredImage).width(600).url() : "/images/jou1.png",
  slug: p.slug?.current
})) : [
  {
    title: "Why Digital Transformation is No Longer Optional",
    desc: "Businesses that delay digital transformation risk falling behind competitors.",
    img: "/images/jou1.png",
    slug: "why-digital-transformation-is-no-longer-optional"
  },
  {
    title: "The Role of Leadership in Organizational Change",
    desc: "Leaders who communicate a clear vision, inspire teams, and adapt to change.",
    img: "/images/jou2.png",
  },
  {
    title: "Strategic Advisory: Turning Vision into Action",
    desc: "Many organizations have big ideas but lack execution.",
    img: "/images/jou3.png",
  },
  {
    title: "Building a Future-Ready Organization",
    desc: "Future-ready companies invest in technology, people, and processes.",
    img: "/images/jou4.png",
  },
  {
    title: "Executive Coaching for High-Impact Leaders",
    desc: "Top executives face constant pressure to perform.",
    img: "/images/jou5.png",
  },
  {
    title: "Overcoming Resistance to Change in the Workplace",
    desc: "Change often brings uncertainty. Organizations that focus.",
    img: "/images/jou6.png",
  },
];
---

<Layout title={page?.seoTitle ?? "Journal | Senquentia"} description={page?.seoDescription}>
  <div class="journal-page">
    <!-- Section 1: Hero -->
    <section class="journal-hero">
      <img src={heroBgUrl} alt="Journal Hero" class="journal-hero-img" />
      <div class="journal-hero-label">
        <h1>{page?.heroLabel ?? "JOURNAL."}</h1>
        <div class="journal-hero-bar"></div>
      </div>
    </section>

    <div class="container2">
      <!-- Section 2: Intro -->
      <section class="journal-intro">
        <h2 class="journal-intro-title">
          {page?.sectionHeadline ?? "ON TRANSFORMATION AND LEADERSHIP"}
        </h2>
      </section>

      <!-- Section 3: Articles Grid -->
      <section class="journal-articles">
        <div class="container">
          <div class="articles-grid">
            {
              articles.map((article) => (
                <div class="article-card">
                  <div class="article-img-box">
                    <img src={article.img} alt={article.title} />
                  </div>
                  <h3 class="article-title">{article.title}</h3>
                  <p class="article-desc">{article.desc}</p>
                  <a
                    href={article.slug ? `/journal/${article.slug}` : "#"}
                    class="article-link"
                  >
                    Read More
                  </a>
                </div>
              ))
            }
          </div>
        </div>
      </section>
    </div>
  </div>
</Layout>
