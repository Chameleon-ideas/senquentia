---
import { urlFor } from "@/utils/sanity";
import { getLang } from "../utils/i18n";

interface Props {
  settings: any;
  lang?: any;
}
const { settings, lang: langProp } = Astro.props;
const currentPath = Astro.url.pathname;
const lang = langProp || getLang(Astro.url);

const logoUrl = settings?.logo ? urlFor(settings.logo).height(88).url() : null;
const linkedinUrl = settings?.linkedin ?? "#";
const enableFR = settings?.enableFR ?? false;

const baseLinks = [
  { label: "Home", labelFR: "Accueil", href: "/" },
  {
    label: "Services",
    labelFR: "Services",
    href: "/#services-section",
    scrollAnchor: true,
    subLinks: [
      { 
        label: "Digital & Organizational Transformation", 
        labelFR: "Transformation numérique et organisationnelle", 
        href: "/services/digital-organizational-transformation" 
      },
      { 
        label: "Strategic Advisory", 
        labelFR: "Conseil stratégique", 
        href: "/services/strategic-advisory" 
      },
      { 
        label: "Leadership Development & Executive Coaching", 
        labelFR: "Développement du leadership et accompagnement des dirigeants", 
        href: "/services/leadership-development-executive-coaching" 
      },
    ]
  },
  { label: "Ethos", labelFR: "Éthos", href: "/ethos" },
  { label: "Journal", labelFR: "Journal", href: "/journal" },
  { label: "Contact", labelFR: "Contact", href: "/contact" },
];

const links = [
  ...baseLinks,
  ...(enableFR ? [{
    label: "FR",
    labelFR: "EN",
    href: "#",
    isLangToggle: true,
  }] : [])
];

function isActive(href: string) {
  if (href === "#") return false;
  const pathWithoutLang = currentPath.replace(/^\/fr(\/|$)/, '/');
  if (href === "/") return pathWithoutLang === "/";
  if (href === "/#services-section") return pathWithoutLang.startsWith("/services");
  return pathWithoutLang.startsWith(href);
}

const langPath = lang === 'fr' ? '/fr' : '';
---

<header class="site-header">
  <!-- Logo -->
  <a
    href={lang === "fr" ? "/fr" : "/"}
    class="nav-logo"
    aria-label={settings?.siteName ?? "Senquentia"}
  >
    <img
      src={logoUrl ?? "/images/logo.png"}
      alt={settings?.siteName ?? "Senquentia"}
      height="44"
      width="auto"
    />
  </a>

  <!-- Desktop nav -->
  <nav aria-label="Main navigation">
    <ul class="nav-links">
        {
          links.map((link: any) => {
            let href = link.href;
            if (!link.isLangToggle && lang === 'fr') {
               href = href.startsWith('/') ? `/fr${href === '/' ? '' : href}` : href;
            }
            return (
              <li class={link.subLinks ? "has-dropdown" : ""}>
                <a
                  href={href}
                  class={isActive(link.href) ? "active" : ""}
                  data-lang-toggle={link.isLangToggle ? "true" : undefined}
                  {...(link.scrollAnchor
                    ? {
                        "data-scroll-anchor": "true",
                        "data-scroll-target": link.href.split("#")[1],
                      }
                    : {})}
                >
                  {lang === "fr" ? link.labelFR : link.label}
                  {link.subLinks && (
                    <svg class="dropdown-arrow" width="10" height="6" viewBox="0 0 10 6" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  )}
                </a>
                {link.subLinks && (
                  <ul class="dropdown-menu">
                    {link.subLinks.map((sub: any) => {
                      let subHref = sub.href;
                      if (lang === 'fr') subHref = `/fr${subHref}`;
                      return (
                        <li>
                          <a href={subHref}>
                            {lang === "fr" ? sub.labelFR : sub.label}
                          </a>
                        </li>
                      );
                    })}
                  </ul>
                )}
              </li>
            );
          })
        }
    </ul>
  </nav>

  <!-- Right side -->
  <div class="nav-right">
    <a
      href={linkedinUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="nav-linkedin"
      aria-label="LinkedIn"
    >
      <img src="/images/linkdinicon.svg" alt="LinkedIn" />
    </a>
    <button class="hamburger" aria-label="Open menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<style>
  @media (max-width: 1024px) {
    /* Handle lang toggle in mobile specially if needed, but for now it's in the list */
  }
</style>

<!-- Mobile nav -->
<nav class="mobile-nav" aria-label="Mobile navigation">
  {
    links.map((link: any) => {
      let href = link.href;
      if (!link.isLangToggle && lang === 'fr') {
         href = href.startsWith('/') ? `/fr${href === '/' ? '' : href}` : href;
      }
      return (
        <>
          <a
            href={link.isLangToggle ? "#" : href}
            class={isActive(link.href) ? "active" : ""}
            data-lang-toggle={link.isLangToggle ? "true" : undefined}
            {...(link.scrollAnchor
              ? {
                  "data-scroll-anchor": "true",
                  "data-scroll-target": link.href.split("#")[1],
                }
              : {})}
          >
            {lang === "fr" ? link.labelFR : link.label}
          </a>
          {link.subLinks && link.subLinks.map((sub: any) => {
             let subHref = sub.href;
             if (lang === 'fr') subHref = `/fr${subHref}`;
             return (
               <a href={subHref} class="mobile-sublink">
                 — {lang === "fr" ? sub.labelFR : sub.label}
               </a>
             );
          })}
        </>
      );
    })
  }
</nav>

<script>
  function initNav() {
    // Language Toggle
    const langToggles = document.querySelectorAll("[data-lang-toggle]");
    langToggles.forEach((toggle) => {
      toggle.addEventListener("click", (e) => {
        e.preventDefault();
        const currentPath = window.location.pathname;
        let nextPath = currentPath;
        
        if (currentPath.startsWith('/fr')) {
          // Switch to English: remove /fr prefix
          nextPath = currentPath.replace(/^\/fr/, '') || '/';
        } else {
          // Switch to French: add /fr prefix
          nextPath = '/fr' + (currentPath === '/' ? '' : currentPath);
        }
        
        // Ensure no double slashes and correct root
        nextPath = nextPath.replace(/\/+/g, '/');
        if (nextPath === '') nextPath = '/';
        
        window.location.href = nextPath;
      });
    });
  }

  // Initialize on load
  initNav();

  // Re-initialize after Astro page transitions
  document.addEventListener("astro:after-swap", initNav);
</script>
