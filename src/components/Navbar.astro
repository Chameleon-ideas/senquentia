---
import { urlFor } from "@/utils/sanity";
import { getLang } from "../utils/i18n";

interface Props {
  settings: any;
}
const { settings } = Astro.props;
const currentPath = Astro.url.pathname;
const lang = getLang(Astro.url);

const logoUrl = settings?.logo ? urlFor(settings.logo).height(88).url() : null;
const linkedinUrl = settings?.linkedin ?? "#";
const enableFR = settings?.enableFR ?? false;

const links = [
  { label: "Home", labelFR: "Accueil", href: "/" },
  {
    label: "Services",
    labelFR: "Services",
    href: "/#services-section",
    scrollAnchor: true,
  },
  { label: "Ethos", labelFR: "Éthique", href: "/ethos" },
  { label: "Journal", labelFR: "Journal", href: "/journal" },
  { label: "Contact", labelFR: "Contact", href: "/contact" },
];

// Add language toggle if enabled in Sanity
if (enableFR) {
  links.push({
    label: "En",
    labelFR: "Fr",
    href: "#",
    isLangToggle: true,
  } as any);
}

function isActive(href: string) {
  if (href === "#") return false;
  if (href === "/") return currentPath === "/";
  if (href === "/#services-section") return currentPath.startsWith("/services");
  return currentPath.startsWith(href);
}
---

<header class="site-header">
  <!-- Logo -->
  <a
    href={lang === "fr" ? "/?lang=fr" : "/"}
    class="nav-logo"
    aria-label={settings?.siteName ?? "Senquentia"}
  >
    <img
      src={logoUrl ?? "/images/logo.png"}
      alt={settings?.siteName ?? "Senquentia"}
      height="44"
      width="auto"
    />
  </a>

  <!-- Desktop nav -->
  <nav aria-label="Main navigation">
    <ul class="nav-links">
      {
        links.map((link: any) => (
          <li>
            <a
              href={link.href}
              class={isActive(link.href) ? "active" : ""}
              data-lang-toggle={link.isLangToggle ? "true" : undefined}
              {...(link.scrollAnchor
                ? {
                    "data-scroll-anchor": "true",
                    "data-scroll-target": link.href.split("#")[1],
                  }
                : {})}
            >
              {lang === "fr" ? link.labelFR : link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>

  <!-- Right side -->
  <div class="nav-right">
    <button id="theme-toggle" class="theme-toggle" aria-label="Toggle theme">
      <svg class="sun-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
      <svg class="moon-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
    </button>
    <a
      href={linkedinUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="nav-linkedin"
      aria-label="LinkedIn"
    >
      <img src="/images/linkdinicon.svg" alt="LinkedIn" />
    </a>
    <button class="hamburger" aria-label="Open menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<style>
  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--clr-text);
    opacity: 0.8;
    transition: opacity 0.2s, transform 0.3s var(--ease);
  }
  .theme-toggle:hover {
    opacity: 1;
    transform: scale(1.1);
  }
  .sun-icon { display: none; }
  .moon-icon { display: block; }

  :global([data-theme="light"]) .sun-icon { display: block; }
  :global([data-theme="light"]) .moon-icon { display: none; }
  :global([data-theme="light"]) .nav-linkedin { filter: invert(1); }
</style>

<!-- Mobile nav -->
<nav class="mobile-nav" aria-label="Mobile navigation">
  {
    links.map((link: any) => (
      <a
        href={link.isLangToggle ? "#" : link.href}
        class={isActive(link.href) ? "active" : ""}
        data-lang-toggle={link.isLangToggle ? "true" : undefined}
        {...(link.scrollAnchor
          ? {
              "data-scroll-anchor": "true",
              "data-scroll-target": link.href.split("#")[1],
            }
          : {})}
      >
        {lang === "fr" ? link.labelFR : link.label}
      </a>
    ))
  }
</nav>

<script>
  function initNav() {
    // Language Toggle
    const langToggles = document.querySelectorAll("[data-lang-toggle]");
    langToggles.forEach((toggle) => {
      toggle.addEventListener("click", (e) => {
        e.preventDefault();
        const url = new URL(window.location.href);
        const currentLang = url.searchParams.get("lang") || "en";
        const nextLang = currentLang === "en" ? "fr" : "en";
        url.searchParams.set("lang", nextLang);
        window.location.href = url.toString();
      });
    });

    // Theme Toggle
    const themeBtn = document.getElementById('theme-toggle');
    if (themeBtn) {
      themeBtn.addEventListener('click', () => {
        const doc = document.documentElement;
        const currentTheme = doc.getAttribute('data-theme') || 'dark';
        const nextTheme = currentTheme === 'dark' ? 'light' : 'dark';
        
        doc.setAttribute('data-theme', nextTheme);
        localStorage.setItem('theme', nextTheme);
      });
    }
  }

  // Initialize on load
  initNav();

  // Re-initialize after Astro page transitions
  document.addEventListener("astro:after-swap", initNav);
</script>
