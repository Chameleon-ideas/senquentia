---
import { urlFor } from '../sanity/image';

interface Props {
  settings: any;
}
const { settings } = Astro.props;
const currentPath = Astro.url.pathname;

const logoUrl = settings?.logo ? urlFor(settings.logo).height(88).url() : null;
const linkedinUrl = settings?.linkedin ?? '#';
const enableFR = settings?.enableFR ?? false;

const links = [
  { label: 'Home',     labelFR: 'Accueil', href: '/' },
  { label: 'Services', labelFR: 'Services', href: '/services' },
  { label: 'Ethos',    labelFR: 'Éthique',  href: '/ethos' },
  { label: 'Journal',  labelFR: 'Journal',  href: '/journal' },
  { label: 'Contact',  labelFR: 'Contact',  href: '/contact' },
];

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header class="site-header">
  <!-- Logo -->
  <a href="/" class="nav-logo" aria-label={settings?.siteName ?? 'Senquentia'}>
    {logoUrl
      ? <img src={logoUrl} alt={settings?.siteName ?? 'Senquentia'} />
      : (
        <svg viewBox="0 0 44 44" width="44" height="44" xmlns="http://www.w3.org/2000/svg">
          <circle cx="22" cy="22" r="20" fill="#c00"/>
          <path d="M22 8 C14 8 8 14 8 22 C8 30 14 36 22 36 C26 36 30 34 32 30 C30 28 28 22 30 18 C32 14 36 12 34 10 C30 6 26 8 22 8Z" fill="white" opacity="0.9"/>
        </svg>
      )
    }
  </a>

  <!-- Desktop nav -->
  <nav aria-label="Main navigation">
    <ul class="nav-links">
      {links.map(link => (
        <li>
          <a
            href={link.href}
            class={isActive(link.href) ? 'active' : ''}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>

  <!-- Right side -->
  <div class="nav-right">
    {enableFR && (
      <button class="nav-lang" data-lang-toggle>FR</button>
    )}
    <a href={linkedinUrl} target="_blank" rel="noopener noreferrer" class="nav-linkedin" aria-label="LinkedIn">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
      </svg>
    </a>
    <button class="hamburger" aria-label="Open menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<!-- Mobile nav -->
<nav class="mobile-nav" aria-label="Mobile navigation">
  {links.map(link => (
    <a href={link.href} class={isActive(link.href) ? 'active' : ''}>
      {link.label}
    </a>
  ))}
</nav>
