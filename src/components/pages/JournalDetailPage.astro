---
import Layout from "../../layouts/Layout.astro";
import { urlFor } from "@/utils/sanity";
import { PortableText } from "astro-portabletext";
import { t } from "@/utils/i18n";
import "../../styles/journal.css";

interface Props {
  post: any;
  lang: "en" | "fr";
}
const { post, lang } = Astro.props;

if (!post) {
  return Astro.redirect(`${lang === "fr" ? "/fr" : ""}/journal`);
}

const title = t(post.title, lang);
const quoteText = t(post.quoteText, lang);
const staggeredTop = t(post.staggeredSection?.topText, lang);
const staggeredBottom = t(post.staggeredSection?.bottomText, lang);

const col1 =
  post.editorialIntro?.col1?.[lang] || post.editorialIntro?.col1?.en || [];
const col2 =
  post.editorialIntro?.col2?.[lang] || post.editorialIntro?.col2?.en || [];

const bodyContent = post.body?.[lang] || post.body?.en || [];
---

<Layout
  title={t(post.seoTitle, lang) || title}
  description={t(post.seoDescription, lang) || t(post.excerpt, lang)}
  ogImage={post.featuredImage
    ? urlFor(post.featuredImage).width(1200).url()
    : undefined}
  lang={lang}
>
  <div class="article-detail-page" style="padding: 0rem 2rem;">
    <!-- Header -->
    <header class="article-detail-header">
      <h1 class="article-detail-title" style="font-weight: 500;">
        {title}
      </h1>
    </header>

    <!-- Editorial Layout Sections -->
    {
      col1.length > 0 && (
        <section class="article-detail-intro-grid">
          <div class="article-detail-text-col">
            <PortableText value={col1} />
          </div>

          <div class="article-vertical-divider" />

          <div class="article-detail-text-col">
            <PortableText value={col2} />
          </div>
        </section>
      )
    }

    <!-- Fallback for standard body if intro is missing -->
    {
      col1.length === 0 && bodyContent.length > 0 && (
        <section
          class="article-detail-intro-grid"
          style="grid-template-columns: 1fr;"
        >
          <div
            class="article-detail-text-col"
            style="max-width: 900px; margin-inline: auto;"
          >
            <PortableText value={bodyContent} />
          </div>
        </section>
      )
    }

    <!-- Quote Section -->
    {
      quoteText && (
        <section class="article-detail-quote-section">
          <p class="article-detail-quote">{quoteText}</p>
        </section>
      )
    }

    <!-- Featured Image -->
    {
      post.featuredImage && (
        <section class="article-detail-image-section">
          <img src={urlFor(post.featuredImage).width(1920).url()} alt={title} />
        </section>
      )
    }

    <!-- Staggered Section -->
    {
      staggeredTop && (
        <section class="article-detail-staggered">
          <div class="staggered-top">
            <div class="article-detail-text-col" style="padding:0;">
              <span>{staggeredTop}</span>
            </div>
          </div>

          <div class="staggered-red-line" />

          <div class="staggered-bottom">
            <div class="article-detail-text-col" style="padding:0;">
              <span>{staggeredBottom}</span>
            </div>
          </div>
        </section>
      )
    }

  </div>
</Layout>
