---
import Layout from "../../layouts/Layout.astro";
import "../../styles/ethos.css";
import { getEthosPage, urlFor } from "@/utils/sanity";
import { t } from "@/utils/i18n";

interface Props {
  lang: "en" | "fr";
}
const { lang } = Astro.props;

const page = await getEthosPage();

const heroBgUrl = page?.heroBgImage
  ? urlFor(page.heroBgImage).width(1920).url()
  : "/images/ethoshero.png";

const founderPhotoUrl = page?.founderPhoto
  ? urlFor(page.founderPhoto).width(800).url()
  : "/images/ethosfounder.png";

const values = page?.values ?? [
  {
    name: lang === "fr" ? "Confiance" : "Trust",
    body:
      lang === "fr"
        ? "Fondée sur la constance, l'intégrité et la transparence."
        : "Built through consistency, integrity, and transparency.",
  },
  {
    name: lang === "fr" ? "Excellence" : "Excellence",
    body:
      lang === "fr"
        ? "Portée par la rigueur, l'expertise et la discipline d'exécution."
        : "Driven by insight, expertise, and disciplined execution.",
  },
  {
    name: lang === "fr" ? "Croissance" : "Growth",
    body:
      lang === "fr"
        ? "Axée sur le développement des capacités et le plein déploiement du potentiel."
        : "Focused on strengthening capabilities and unlocking potential.",
  },
  {
    name: lang === "fr" ? "Partenariat" : "Partnership",
    body:
      lang === "fr"
        ? "Ancré dans un engagement commun à générer des résultats durables et significatifs."
        : "Defined by shared commitment to meaningful, lasting outcomes.",
  },
];
---

<Layout
  title={t(page?.seoTitle, lang) ||
    (lang === "fr" ? "Éthos | Senquentia" : "Ethos | Senquentia")}
  description={t(page?.seoDescription, lang) ||
    (lang === "fr"
      ? "Les principes et les perspectives qui façonnent notre travail."
      : "The principles and perspectives that shape our work.")}
  lang={lang}
>
  <div class="ethos-page-wrapper">
    <!-- Section 1: Hero -->
    <section class="ethos-hero">
      <div class="ethos-hero-bg">
        <img src={heroBgUrl} alt="Ethos Hero" />
      </div>
      <div class="ethos-hero-label" style="font-weight: 400;">
        <h2>
          {t(page?.heroLabel, lang) || (lang === "fr" ? "ÉTHOS." : "ETHOS.")}
        </h2>
        <div class="ethos-hero-bar"></div>
      </div>
    </section>

    <!-- Section 2: Principles -->
    <section class="ethos-principles">
      <div class="container">
        <div class="principles-headline-row">
          <h2
            class="principles-headline"
            style="font-weight: 400;"
            set:html={t(page?.principlesHeadline, lang) ||
              (lang === "fr"
                ? "Les principes et les <br /> perspectives <br /> qui façonnent notre travail."
                : "THE PRINCIPLES AND <br /> PERSPECTIVES <br /> THAT SHAPE OUR WORK.")}
          />
        </div>

        <div class="principles-grid">
          <div class="principles-left">
            <h3 class="ethos-label" style="font-weight: 500;">
              {lang === "fr" ? "ÉTYMOLOGIE" : "ETYMOLOGY"}
            </h3>
            <p class="ethos-body-text margin-left20">
              {
                t(page?.etymologyDesc, lang) ||
                  (lang === "fr"
                    ? "À l'origine de notre philosophie, de nos valeurs et de notre raison d'être."
                    : "Tracing the roots of our philosophy, values, and purpose as a firm.")
              }
            </p>

            <div class="etymology-details">
              <div class="etymology-item">
                <span class="etymology-tag"
                  >{
                    lang === "fr"
                      ? "une manière de pensée"
                      : "a way of thinking"
                  }</span
                >
                <div class="etymology-word-line">
                  <span style="font-weight: 600;">sen</span>tentia <span
                    class="etymology-word-line-span">[sɛnˈtɛn.ti.a] :</span
                  >
                </div>
              </div>
              <div class="etymology-item align-start">
                <div class="etymology-word-line">
                  <span>: [eː.ɫɔˈkʷɛn.ti.a] elo<strong>quentia</strong></span>
                </div>
                <span class="etymology-meaning"
                  >{
                    lang === "fr"
                      ? "l'art de l'expression : Eloquentia"
                      : "the art of fluency"
                  }</span
                >
              </div>
            </div>
          </div>

          <div class="principles-divider"></div>

          <div class="principles-right">
            <h3 class="ethos-label" style="font-weight: 500;">
              {lang === "fr" ? "PHILOSOPHIE" : "PHILOSOPHY"}
            </h3>
            <div class="ethos-body-text margin-right20">
              {
                page?.philosophyBody ? (
                  <p>{t(page.philosophyBody, lang)}</p>
                ) : lang === "fr" ? (
                  <>
                    <p>
                      Chez Senquentia, nous remettons en question les idées
                      reçues et apportons de la clarté dans des environnements
                      complexes.
                    </p>
                    <br />
                    <p>
                      Nous conjuguons perspective stratégique et mise en œuvre
                      concrète afin d'aider les dirigeants à prendre des
                      décisions éclairées et à mener des transformations
                      porteuses de sens.
                    </p>
                  </>
                ) : (
                  <>
                    <p>
                      At Senquentia, we challenge conventional thinking and
                      provide clarity in complex environments.
                    </p>
                    <br />
                    <p>
                      We combine strategic insight with practical execution to
                      help leaders make informed decisions and drive meaningful
                      change.
                    </p>
                  </>
                )
              }
            </div>

            <div class="ethos-quote-box">
              <h3 class="ethos-quote-text" style="font-weight: 500;">
                {
                  t(page?.philosophyQuote, lang) ||
                    (lang === "fr"
                      ? "L'expérience apporte la perspective, mais c'est l'intégrité qui inspire la confiance."
                      : "Experience brings perspective, but integrity is what earns trust.")
                }
              </h3>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Section 3: Values -->
    <section class="ethos-values">
      <div class="container">
        <div class="values-intro">
          <h2 class="values-main-title" style="font-weight: 400;">
            {lang === "fr" ? "VALEURS" : "VALUES"}
          </h2>
          <p class="values-intro-desc">
            {
              t(page?.valuesDesc, lang) ||
                (lang === "fr"
                  ? "Nos valeurs ont guidé chaque étape de notre parcours et continuent de façonner notre perspective et notre approche."
                  : "Our values have shaped every step of our journey and continue to define our perspective.")
            }
          </p>
        </div>

        <div class="values-red-line"></div>

        <div class="values-grid">
          {
            values.map((v: any) => (
              <div class="value-card">
                <h3 class="value-card-name">{t(v.name, lang)}</h3>
                <p class="value-card-body">{t(v.body, lang)}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Section 4: Founder -->
    <section class="ethos-founder">
      <div class="container2 founder-inner-pading">
        <div class="founder-white-card">
          <div class="founder-img-box">
            <img src={founderPhotoUrl} alt="Veronica Eleonora Palumbo" />
          </div>

          <h2 class="founder-label-top">
            {lang === "fr" ? "FONDATRICE" : "FOUNDER"}
          </h2>

          <div class="founder-info">
            <h3 class="founder-headline">
              {
                t(page?.founderTitle, lang) ||
                  (lang === "fr"
                    ? "Veronica Eleonora Palumbo est une conseillère auprès des dirigeants, alliant réflexion stratégique et mise en œuvre."
                    : "Veronica Eleonora Palumbo is an executive advisor fluent in both strategy and delivery.")
              }
            </h3>

            <div class="founder-red-divider"></div>

            <div class="founder-bio-text">
              {
                page?.founderBio ? (
                  <p>{t(page.founderBio, lang)}</p>
                ) : lang === "fr" ? (
                  <>
                    <p>
                      Forte de 20 années d'expérience dans la direction de
                      programmes ERP et d'une expertise en solutions de gestion
                      du capital humain, elle est une voix reconnue en
                      transformation numérique et organisationnelle, apportant
                      des perspectives nouvelles à la définition d'initiatives
                      stratégiques. Elle a dirigé plusieurs mandats
                      multinationaux et piloté des équipes de livraison à
                      l'échelle mondiale, développant une expertise approfondie
                      des déploiements à grande échelle.
                    </p>
                    <p>
                      À titre de conseillère stratégique, Veronica accompagne
                      les équipes de direction dans leurs initiatives critiques,
                      les fusions et acquisitions, ainsi que les transformations
                      culturelles, en s'appuyant sur son expertise en
                      développement organisationnel, planification de la relève
                      et gestion du changement.
                    </p>
                  </>
                ) : (
                  <>
                    <p>
                      With 20 years of experience leading ERP programs and
                      expertise in Human Capital Management solutions, she is a
                      trusted voice in digital and organizational
                      transformation, bringing fresh perspectives to defining
                      business initiatives. She has led several multinational
                      engagements and directed global delivery teams, honing her
                      expertise in large-scale implementations.
                    </p>
                    <p>
                      As a strategic advisor, Veronica has partnered with
                      executive teams to navigate critical business initiatives,
                      mergers and acquisitions, and culture shifts, leveraging
                      her skills in organizational development, succession
                      planning, and change management.
                    </p>
                  </>
                )
              }
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>
