---
import Layout from "../../layouts/Layout.astro";
import { getHomePage, getServices, urlFor } from "@/utils/sanity";
import { t } from "@/utils/i18n";

interface Props {
  lang: 'en' | 'fr';
}
const { lang } = Astro.props;

const [page, services] = await Promise.all([getHomePage(), getServices()]);

const imageObj = lang === 'fr' && page?.heroBgImageFR ? page.heroBgImageFR : page?.heroBgImage;
const heroImageSrc = imageObj
  ? urlFor(imageObj).width(1920).url()
  : "/images/heroEng.png";

const ctaBgStyle = page?.ctaBgImage
  ? `background-image:url('${urlFor(page.ctaBgImage).width(1920).url()}')`
  : `background-image:url('/images/contactbg.png')`;

const stats = page?.stats ?? [
  {
    number: "500M+",
    label: {
      en: "Program budget oversight",
      fr: "Surveillance du budget du programme",
    },
  },
  {
    number: "25+",
    label: {
      en: "ERP Transformation Programs",
      fr: "Programmes de transformation ERP",
    },
  },
  {
    number: "30+",
    label: {
      en: "HCM Transformation Programs",
      fr: "Programmes de transformation HCM",
    },
  },
  {
    number: "10+",
    label: { en: "Mergers & Acquisitions", fr: "Fusions et acquisitions" },
  },
];

const industries =
  lang === "fr"
    ? [
        "Sociétés d'État et entités du secteur public",
        "Services bancaires et financiers",
        "Énergie et services publics",
        "Assurance",
        "Aviation et aérospatiale",
        "Transport et logistique",
        "Services de construction et d'ingénierie",
        "Pâte, papier et foresterie",
        "Mines et ressources naturelles",
        "Commerce de détail et biens de consommation",
        "Fabrication d'aliments et de boissons",
        "Enseignement supérieur et institutions académiques",
      ]
    : [
        "Crown Corporations & Public Sector Entities",
        "Banking & Financial Services",
        "Energy & Utilities",
        "Insurance",
        "Aviation & Aerospace",
        "Transportation & Logistics",
        "Construction & Engineering Services",
        "Pulp, Paper, & Forestry",
        "Mining & Natural Resources",
        "Retail & Consumer Goods",
        "Food & Beverage Manufacturing",
        "Higher Education & Academic Institutions",
      ];

const displayServices = services?.length
  ? services
    : [
        {
          title: {
            en: "Digital & Organizational Transformation",
            fr: "Transformation numérique et organisationnelle",
          },
          slug: { current: "digital-organizational-transformation" },
        },
        {
          title: { en: "Strategic Advisory", fr: "Conseil stratégique" },
          slug: { current: "strategic-advisory" },
        },
        {
          title: {
            en: "Leadership Development & Executive Coaching",
            fr: "Développement du leadership et coaching de dirigeants",
          },
          slug: { current: "leadership-development-executive-coaching" },
        },
      ];
---

<Layout
  title={t(page?.seoTitle, lang)}
  description={t(page?.seoDescription, lang)}
  lang={lang}
>
  <!-- ═══ HERO ══════════════════════════════════════════════ -->
  <section class="home-hero">
    <img src={heroImageSrc} alt="Senquentia" class="home-hero-img" />
  </section>

  <!-- ═══ INTRO ════════════════════════════════════════════ -->
  <section class="intro-section">
    <div class="container2">
      <div class="intro-eyebrow-wrapper">
        <p class="intro-eyebrow">
          {
            t(page?.introEyebrow, lang) ||
              (lang === "fr"
                ? "Bienvenue chez Senquentia"
                : "Welcome to Senquentia")
          }
        </p>
        <div class="intro-eyebrow-line"></div>
      </div>
      <div class="intro-grid">
        <div class="intro-left">
          <h2
            class="intro-heading reveal-left"
            set:html={t(page?.introHeadline, lang)
              ? t(page.introHeadline, lang).replace(/\n/g, "<br/>")
              : lang === "fr"
                ? "OÙ LE LEADERSHIP<br/>RENCONTRE LA<br/>TRANSFORMATION"
                : "WHERE LEADERSHIP<br/>MEETS<br/>TRANSFORMATION"}
          />
        </div>
        <div class="intro-v-divider"></div>
        <div class="intro-right reveal-right">
          <p class="intro-lead">
            {
              t(page?.introLead, lang) ||
                (lang === "fr"
                  ? "Depuis 2010, nous nous associons aux équipes de direction pour mener des transformations numériques et organisationnelles complexes."
                  : "Since 2010, we have partnered with executive teams to lead complex digital and organizational transformation.")
            }
          </p>
          <div class="intro-body">
            {
              (page?.introBody1 || page?.introBody2 || page?.introBody3) ? (
                <>
                  {page?.introBody1 && <p>{t(page.introBody1, lang)}</p>}
                  {page?.introBody2 && <p>{t(page.introBody2, lang)}</p>}
                  {page?.introBody3 && <p>{t(page.introBody3, lang)}</p>}
                </>
              ) : lang === "fr" ? (
                <>
                  <p>
                    Grâce à nos services de conseil en stratégie et en gestion,
                    les organisations naviguent dans la complexité et stimulent
                    des changements significatifs — soutenus par une perspective
                    stratégique et une approche pragmatique et concrète.
                  </p>
                  <p>
                    Notre travail est fondé sur la confiance et façonné par le
                    contexte unique de chaque organisation.
                  </p>
                  <p>
                    Nous nous concentrons sur la production d'un impact durable.
                  </p>
                </>
              ) : (
                <>
                  <p>
                    Through our strategy and management consulting services,
                    organizations navigate complexity and drive meaningful
                    change — supported by strategic perspective and a pragmatic,
                    hands-on approach.
                  </p>
                  <p>
                    Our work is grounded in trust and shaped by the unique
                    context of each organization.
                  </p>
                  <p>We focus on delivering lasting impact.</p>
                </>
              )
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ SERVICES ══════════════════════════════════════════ -->
  <section class="services-wrap">
    {
      page?.servicesBgImage ? (
        <img
          class="services-bg-img"
          src={urlFor(page.servicesBgImage).width(1920).url()}
          alt={t(page.servicesBgImage.alt, lang) || ""}
        />
      ) : (
        <img class="services-bg-img" src="/images/services.png" alt="" />
      )
    }
    <div class="services-overlay" id="services-section">
      <div class="container2">
        <div class="services-overlay-inner">
          {
            displayServices.slice(0, 3).map((s: any, i: number) => {
              const fallbackImages = [
                "/images/servicesbox1.png",
                "/images/servicesbox2.png",
                "/images/servicebox3.png",
              ];
              const fallbackUrl = fallbackImages[i] || "/images/services.png";
              const imgUrl =
                s.mainImage || s.image
                  ? `url('${urlFor(s.mainImage || s.image)
                      .width(600)
                      .url()}')`
                  : `url('${fallbackUrl}')`;
              const bgImg = `linear-gradient(rgba(248, 246, 242, 0.7), rgba(248, 246, 242, 0.7)), ${imgUrl}`;
              return (
                <a
                  href={`${lang === 'fr' ? '/fr' : ''}/services/${s.slug?.current ?? s.slug}`}
                  class="service-overlay-item reveal-up"
                  style={`background-image: ${bgImg}`}
                >
                  <div class="service-overlay-inner-box">
                    <div class="service-overlay-title">{t(s.title, lang)}</div>
                  </div>
                </a>
              );
            })
          }
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ STATS ════════════════════════════════════════════ -->
  <section class="stats-bar">
    <div class="container2">
      <div class="stats-grid">
        {
          stats.map((stat: any) => (
            <div class="reveal-up">
              <div class="stat-number">{stat.number ?? stat.value}</div>
              <div class="stat-label">{t(stat.label, lang)}</div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ═══ TICKER ════════════════════════════════════════════ -->
  <div class="container2 spacing">
    <div class="ticker-wrap" aria-hidden="true">
      <div class="ticker-track">
        {
          [...industries, ...industries].map((item) => (
            <span class="ticker-item">{item}</span>
          ))
        }
      </div>
    </div>
  </div>

  <!-- ═══ CTA ══════════════════════════════════════════════ -->
  <section class="home-cta">
    <div class="home-cta-bg" style={ctaBgStyle}></div>
    <div class="container2">
      <div class="home-cta-content">
        <div class="home-cta-text-wrapper reveal-right">
          <p class="home-cta-text">
            {
              t(page?.ctaText, lang) ||
                (lang === "fr"
                  ? "Notre travail commence par une conversation."
                  : "Our work begins in conversation.")
            }
          </p>
          <a href={`${lang === 'fr' ? '/fr' : ''}/contact`} class="home-cta-link">
            {
              t(page?.ctaLinkLabel, lang) ||
                (lang === "fr" ? "Connecter." : "Connect.")
            }
          </a>
        </div>
        <div class="home-cta-bar"></div>
      </div>
    </div>
  </section>
</Layout>
