---
import Layout from "../../layouts/Layout.astro";
import { getContactPage, urlFor } from "@/utils/sanity";
import { t } from "@/utils/i18n";

interface Props {
  lang: 'en' | 'fr';
}
const { lang } = Astro.props;

const page = await getContactPage();

const heroBgUrl = page?.heroBgImage 
  ? urlFor(page.heroBgImage).width(1920).url() 
  : "/images/contactbg.png";
---

<Layout 
  title={t(page?.seoTitle, lang) || (lang === 'fr' ? "Contact" : "Contact")} 
  description={t(page?.seoDescription, lang)}
  lang={lang}
>
  <!-- ═══ CONTACT HERO ══════════════════════════════════════ -->
  <section class="contact-hero">
    <div class="contact-hero-bg" style={`background-image: url('${heroBgUrl}')`}></div>
    <div class="container2">
       <div class="contact-top-label reveal-left">
          <h2>CONTACT</h2>
       </div>
    </div>
  </section>

  <!-- ═══ CONTACT CONTENT ═══════════════════════════════════ -->
  <section class="contact-section">
    <div class="contact-top-bar"></div>
    <div class="container2">
      <div class="contact-grid">
        <div class="contact-left reveal-left">
          <h2 class="contact-heading">
            {t(page?.leadText, lang) || (lang === 'fr' ? "Notre travail débute dans le dialogue." : "Our work begins in conversations.")}
          </h2>
          <p class="contact-subheading">
            {lang === 'fr' ? "Échanger." : "Connect."}
          </p>
        </div>

        <div class="contact-right reveal-right">
          <form class="contact-form" action="#" method="POST">
            <div class="form-grid">
              <div class="form-group">
                <input type="text" id="name" name="name" placeholder={lang === 'fr' ? "Nom" : "Name"} required />
              </div>
              <div class="form-group">
                <input type="text" id="org" name="org" placeholder={lang === 'fr' ? "Organisation" : "Organization"} />
              </div>
              <div class="form-group">
                <input type="email" id="email" name="email" placeholder={lang === 'fr' ? "Courriel" : "Email"} required />
              </div>
              <div class="form-group">
                <input type="tel" id="phone" name="phone" placeholder={lang === 'fr' ? "Téléphone" : "Phone"} />
              </div>
            </div>

            <div class="form-group select-group">
              <label>{lang === 'fr' ? "Domaine d’intérêt" : "Area of Interest"}:</label>
              <div class="radio-grid">
                 <label class="radio-item">
                    <input type="radio" name="interest" value="transformation" checked />
                    <span>{lang === 'fr' ? "Transformation numérique et organisationnelle" : "Digital & Organizational Transformation"}</span>
                 </label>
                 <label class="radio-item">
                    <input type="radio" name="interest" value="advisory" />
                    <span>{lang === 'fr' ? "Conseil stratégique" : "Strategic Advisory"}</span>
                 </label>
                 <label class="radio-item">
                    <input type="radio" name="interest" value="coaching" />
                    <span>{lang === 'fr' ? "Développement du leadership et accompagnement des dirigeants" : "Leadership Development & Executive Coaching"}</span>
                 </label>
                 <label class="radio-item">
                    <input type="radio" name="interest" value="other" />
                    <span>{lang === 'fr' ? "Autre" : "Other"}</span>
                 </label>
              </div>
            </div>

            <div class="form-group">
              <textarea id="message" name="message" rows="5" placeholder={lang === 'fr' ? "Message" : "Message"} required></textarea>
            </div>

            <div class="form-footer">
               <button type="submit" class="submit-btn">{lang === 'fr' ? "Envoyer" : "Send"}</button>
            </div>
          </form>
          
          <div class="contact-footer-right">
             <p class="contact-footer-text">
               {t(page?.disclaimer, lang) || (lang === 'fr' ? "Toutes les demandes sont traitées avec discrétion et confidentialité." : "We treat all inquiries with discretion and confidentiality.")}
             </p>
             <a href={`mailto:${page?.email || 'info@senquentia.com'}`} class="contact-email">
               {page?.email || 'info@senquentia.com'}
             </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
