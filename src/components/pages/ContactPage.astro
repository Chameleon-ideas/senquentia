---
import Layout from "../../layouts/Layout.astro";
import { getConnectPage, urlFor } from "@/utils/sanity";
import { t } from "@/utils/i18n";
import "../../styles/contact.css";

interface Props {
  lang: "en" | "fr";
}
const { lang } = Astro.props;

const page = await getConnectPage();

const heroBgUrl = page?.heroBgImage
  ? urlFor(page.heroBgImage).width(1920).url()
  : "/images/contactbg.png";

const email = page?.email ?? "info@senquentia.com";
---

<Layout
  title={t(page?.seoTitle, lang) ||
    (lang === "fr" ? "Contact | Senquentia" : "Contact | Senquentia")}
  description={t(page?.seoDescription, lang)}
  lang={lang}
>
  <div
    class="contact-page-outer"
    style={`background-image: url(${heroBgUrl});`}
  >
    <div class="contact-page-inner">
      <!-- Top Right Label -->
      <div class="contact-top-label">
        <h2>{lang === "fr" ? "CONTACT" : "CONTACT"}</h2>
        <div class="contact-top-bar"></div>
      </div>

      <div class="container">
        <main class="contact-content-main">
          <!-- Intro Text -->
          <div class="contact-intro-text">
            <p>
              {
                t(page?.leadText, lang) ||
                  (lang === "fr"
                    ? "Notre travail commence par une conversation."
                    : "Our work begins in conversation.")
              }
            </p>
            <p>{lang === "fr" ? "Échanger." : "Connect."}</p>
          </div>

          <!-- Red Line -->
          <div class="contact-red-line"></div>

          <!-- Form Grid -->
          <form
            id="connect-form"
            class="contact-form-grid"
            method="POST"
            action="/api/contact"
          >
            <!-- Left Col -->
            <div class="contact-form-col">
              <input
                type="text"
                name="name"
                placeholder={lang === "fr" ? "Nom" : "Name"}
                class="contact-field"
                required
              />
              <input
                type="text"
                name="organization"
                placeholder={lang === "fr" ? "Organisation" : "Organization"}
                class="contact-field"
              />
              <input
                type="email"
                name="email"
                placeholder={lang === "fr" ? "Courriel" : "Email"}
                class="contact-field"
                required
              />
              <input
                type="tel"
                name="phone"
                placeholder={lang === "fr" ? "Téléphone" : "Phone"}
                class="contact-field"
              />
            </div>

            <!-- Right Col -->
            <div class="contact-form-col">
              <select name="area" class="contact-field" required>
                <option value="" disabled selected>
                  {lang === "fr" ? "Domaine d'intérêt" : "Area of interest"}
                </option>
                <option value="Digital & Organizational Transformation">
                  {lang === "fr"
                    ? "Transformation numérique et organisationnelle"
                    : "Digital & Organizational Transformation"}
                </option>
                <option value="Strategic Advisory">
                  {lang === "fr" ? "Conseil stratégique" : "Strategic Advisory"}
                </option>
                <option value="Leadership Development & Executive Coaching">
                  {lang === "fr"
                    ? "Développement du leadership et accompagnement des dirigeants"
                    : "Leadership Development & Executive Coaching"}
                </option>
                <option value="Other">
                  {lang === "fr" ? "Autre" : "Other"}
                </option>
              </select>
              <textarea
                name="message"
                placeholder="Message"
                class="contact-field contact-textarea"
                required></textarea>
            </div>
          </form>

          <!-- Footer row moved outside the grid to allow more width -->
          <div class="contact-footer-right">
            <button
              type="submit"
              id="send-btn"
              form="connect-form"
              class="contact-submit-btn"
            >
              {lang === "fr" ? "Envoyer" : "Send"}
            </button>

            <div class="contact-footer-text">
              <p class="contact-disclaimer">
                {
                  t(page?.disclaimer, lang) ||
                    (lang === "fr"
                      ? "Toutes les demandes sont traitées avec discrétion et confidentialité."
                      : "We treat all inquiries with discretion and confidentiality.")
                }
              </p>
              <a href={`mailto:${email}`} class="contact-email-link-footer"
                >{email}</a
              >
            </div>
          </div>
        </main>
      </div>
    </div>
  </div>
</Layout>

<script>
  const form = document.getElementById(
    "connect-form",
  ) as HTMLFormElement | null;
  const btn = document.getElementById("send-btn") as HTMLButtonElement | null;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!btn) return;
    btn.disabled = true;
    const originalText = btn.textContent;
    btn.textContent = "Sending…";

    const data = Object.fromEntries(new FormData(form));
    try {
      const res = await fetch("/api/contact", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
      });
      if (!res.ok) throw new Error();
      btn.textContent = "Sent ✓";
      form.reset();
      setTimeout(() => {
        btn.disabled = false;
        btn.textContent = originalText;
      }, 3000);
    } catch {
      btn.disabled = false;
      btn.textContent = originalText;
      alert("Something went wrong. Please try again or email us directly.");
    }
  });
</script>
