---
import { urlFor } from "@/utils/sanity";
import { getLang } from "../utils/i18n";

interface Props {
  settings: any;
}
const { settings } = Astro.props;
const lang = getLang(Astro.url);

const logoUrl = settings?.logo ? urlFor(settings.logo).height(72).url() : null;
const siteName = settings?.siteName ?? "Senquentia";
const tagline = settings?.tagline ?? "Strategy & Management Consulting";
const address = settings?.address ?? "Montréal, Quebec, Canada";
const email = settings?.email ?? "info@senquentia.com";
const linkedin = settings?.linkedin ?? "#";
---

<footer class="site-footer">
  <div class="container2">
    <div class="footer-inner">
      <!-- Brand -->
      <div class="footer-brand">
        <a
          href={lang === "fr" ? "/?lang=fr" : "/"}
          class="footer-logo"
          aria-label={siteName}
        >
          {
            logoUrl ? (
              <img src={logoUrl} alt={siteName} />
            ) : (
              <img src="/images/footerlogo3.png" alt={siteName} />
            )
          }
        </a>
        {logoUrl && tagline && <p class="footer-tagline">{tagline}</p>}
      </div>

      <!-- Contact info -->
      <div class="footer-right">
        {address && <span class="footer-info">{address}</span>}
        {email && <span class="footer-email">{email}</span>}
        <div class="footer-contact-row">
          <a href="/contact" class="footer-contact-link"
            >{lang === "fr" ? "Contact" : "Contact"}</a
          >
          <a
            href={linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="footer-linkedin"
            aria-label="LinkedIn"
          >
            <img src="/images/linkdinicon.svg" alt="LinkedIn" />
          </a>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <span> Copyright </span>
    </div>
  </div>
</footer>
