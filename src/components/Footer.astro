import { urlFor } from "@/utils/sanity";
import { getLang, t } from "../utils/i18n";

interface Props {
  settings: any;
  footerData: any;
}
const { settings, footerData } = Astro.props;
const lang = getLang(Astro.url);

const logoUrl = settings?.logo ? urlFor(settings.logo).height(72).url() : null;
const siteName = t(footerData?.companyName, lang) || t(settings?.siteName, lang) || "Senquentia";
const tagline = t(settings?.tagline, lang) || (lang === 'fr' ? "Conseil en stratégie et management" : "Strategy & Management Consulting");
const address = t(footerData?.address, lang) || t(settings?.address, lang) || "Montréal, Quebec, Canada";
const email = footerData?.email ?? settings?.email ?? "info@senquentia.com";
const linkedin = footerData?.linkedinUrl ?? settings?.linkedin ?? "#";
const copyrightText = t(footerData?.copyrightText, lang) || (lang === 'fr' ? `© ${new Date().getFullYear()} Senquentia. Tous droits réservés.` : `© ${new Date().getFullYear()} Senquentia. All rights reserved.`);
---

<footer class="site-footer">
  <div class="container2">
    <div class="footer-inner">
      <!-- Brand -->
      <div class="footer-brand">
        <a
          href={lang === "fr" ? "/?lang=fr" : "/"}
          class="footer-logo"
          aria-label={siteName}
        >
          {
            logoUrl ? (
              <img src={logoUrl} alt={siteName} />
            ) : (
              <img src="/images/footerlogo3.png" alt={siteName} />
            )
          }
        </a>
        {logoUrl && tagline && <p class="footer-tagline">{tagline}</p>}
      </div>

      <!-- Contact info -->
      <div class="footer-right">
        {address && <span class="footer-info">{address}</span>}
        {email && <span class="footer-email">{email}</span>}
        <div class="footer-contact-row">
          <a href={`/contact?lang=${lang}`} class="footer-contact-link"
            >{lang === "fr" ? "Contact" : "Contact"}</a
          >
          <a
            href={linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="footer-linkedin"
            aria-label="LinkedIn"
          >
            <img src="/images/linkdinicon.svg" alt="LinkedIn" />
          </a>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <span>{copyrightText} Designed and Developed by <a href="https://chameleon-ideas.com" target="_blank" rel="noopener noreferrer">Chameleon Ideas</a></span>
    </div>
  </div>
</footer>
